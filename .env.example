# CyberSentinel DLP - Environment Configuration
# Copy this file to .env and configure with your values

# ============================================
# SECURITY SETTINGS (CHANGE THESE!)
# ============================================
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
JWT_SECRET=change-this-to-a-random-jwt-secret-min-32-chars

# Initial admin password — used ONLY when seeding the first admin on a brand-new
# database. Leave EMPTY and the manager generates a random one and logs it once
# (docker logs cybersentineldlp-manager 2>&1 | grep generated_password). Set it to
# pin the password from your own secrets manager for automated deployments.
# Must be 7+ chars with upper, lower, digit and a symbol.
DLP_ADMIN_PASSWORD=
ENCRYPTION_KEY=change-this-to-a-random-encryption-key
POSTGRES_PASSWORD=change-this-strong-postgres-password
MONGODB_PASSWORD=change-this-strong-mongodb-password
REDIS_PASSWORD=change-this-strong-redis-password
OPENSEARCH_PASSWORD=change-this-strong-opensearch-password

# ============================================
# TIMEZONE CONFIGURATION
# ============================================
# Timestamps are stored in UTC; this controls display timezone in API responses.
# Examples: UTC, Asia/Kolkata, US/Eastern, Europe/London, America/New_York
APP_TIMEZONE=UTC

# ============================================
# NETWORK CONFIGURATION
# ============================================
# Your Ubuntu server's IP address (used for display purposes)
HOST_IP=your-ubuntu-server-ip

# Host port for the dashboard. Container-side nginx always listens on
# 3000 (unprivileged). Change this if 3023 is already in use on the
# host — any free port works, e.g. 8443, 4000, 3000.
DASHBOARD_HOST_PORT=3023

# NOTE: VITE_API_URL is NOT needed when using pre-built GHCR images.
# The dashboard uses relative URLs (/api/v1) and nginx proxies to the backend.

# TLS certificates for the dashboard container. docker-compose.prod.yml mounts
# ${TLS_CERT_PATH}/fullchain.pem and ${TLS_CERT_PATH}/privkey.pem. These files
# MUST exist before `up -d` — if absent, Docker creates them as empty
# directories and the dashboard fails to start. install.sh generates a
# self-signed pair; for a manual install create ./certs yourself (see README).
TLS_CERT_PATH=./certs

# ============================================
# DATABASE SETTINGS
# ============================================
# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=dlp_user
POSTGRES_DB=cybersentineldlp

# MongoDB Configuration
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USER=dlp_user
MONGODB_DB=cybersentineldlp

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# OpenSearch Configuration (Event Storage & Search)
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=change-this-strong-opensearch-password
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX_PREFIX=cybersentineldlp

# ============================================
# APPLICATION SETTINGS
# ============================================
ENVIRONMENT=production
DEBUG=False
PORT=55000
APP_NAME=CyberSentinel DLP
APP_VERSION=2.1.6

# ============================================
# CORS SETTINGS (Add your dashboard URLs)
# ============================================
# SECURITY: CORS and trusted-host allowlists.
# The dashboard is served from the same origin as the API via the nginx
# reverse proxy, so no cross-origin access is needed. Wide-open "*" was
# removed — set these to the explicit hostname(s) you serve the dashboard
# under in production. Example:
#   CORS_ORIGINS=["https://dlp.mycompany.com"]
#   ALLOWED_HOSTS=dlp.mycompany.com,127.0.0.1
CORS_ORIGINS=["http://localhost","http://127.0.0.1"]
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# EMAIL ALERTS (OPTIONAL)
# ============================================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@company.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=dlp-alerts@company.com
ALERT_EMAIL=admin@company.com

# ============================================
# WAZUH SIEM INTEGRATION (OPTIONAL)
# ============================================
WAZUH_ENABLED=false
WAZUH_HOST=your-wazuh-server
WAZUH_PORT=55000
WAZUH_USER=wazuh-api-user
WAZUH_PASSWORD=wazuh-api-password

# ============================================
# LOGGING SETTINGS
# ============================================
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/cybersentineldlp
MAX_LOG_SIZE_MB=100
LOG_RETENTION_DAYS=30

# ============================================
# QUARANTINE SETTINGS
# ============================================
QUARANTINE_ENABLED=true
QUARANTINE_PATH=/var/quarantine/dlp
QUARANTINE_MAX_SIZE_GB=50

# ============================================
# PERFORMANCE TUNING
# ============================================
MAX_WORKERS=4
MAX_CONNECTIONS=100
REQUEST_TIMEOUT=30

# ============================================
# OCR (OPTIONAL — scanned PDFs & images)
# ============================================
# The manager image ships Tesseract + poppler, so OCR works out of the box.
# These only tune it. OCR is graceful: if the engine is ever unavailable, image/
# scanned files are reported "uninspectable" (blocked by policy), never "clean".
DLP_OCR_ENABLED=1
DLP_OCR_MAX_PAGES=20          # max pages OCR'd from a scanned PDF
DLP_OCR_DPI=200              # render resolution for PDF pages
DLP_OCR_LANG=eng            # Tesseract language(s); add packs for others, e.g. eng+hin
DLP_OCR_PAGE_TIMEOUT=30     # seconds per page/image

# ============================================
# COMPLIANCE SETTINGS
# ============================================
COMPLIANCE_MODE=GDPR,HIPAA,PCI-DSS
DATA_RETENTION_DAYS=90
AUDIT_LOG_ENABLED=true

# ============================================
# EMAIL DLP — outbound SMTP relay (OPT-IN)
# ============================================
# The relay inspects outbound mail (body + attachments) and rejects messages
# carrying Confidential/Restricted content with a 550 at DATA. It is gated
# behind a compose profile, so it stays off until you ask for it:
#   docker compose -f docker-compose.prod.yml --profile email-dlp up -d
#
# REQUIRED: register an agent on the manager, then paste its id + api_key here.
# The relay REFUSES TO START without a key — otherwise it would forward every
# message uninspected while looking like it enforces email DLP.
#   curl -X POST http://localhost:55000/api/v1/agents/ -H 'Content-Type: application/json' \
#     -d '{"agent_id":"smtp-relay","name":"SMTP Relay (Email DLP)","os":"linux","ip_address":"127.0.0.1","version":"2.1.6"}'
RELAY_AGENT_ID=smtp-relay
RELAY_AGENT_KEY=

# Where CLEAN mail goes next. LEAVE BLANK AND NOTHING IS DELIVERED (test mode
# — the relay accepts and drops). Set this before putting it in a real mail flow.
RELAY_NEXT_HOP_HOST=
RELAY_NEXT_HOP_PORT=587
RELAY_NEXT_HOP_USER=
RELAY_NEXT_HOP_PASS=
RELAY_NEXT_HOP_STARTTLS=true

RELAY_HOST_PORT=10025
# true = reject mail whose attachments cannot be read (encrypted archives,
# scanned-image PDFs, legacy .doc). "Uninspectable" must not mean "clean",
# but this does bounce some legitimate mail.
RELAY_BLOCK_UNEXTRACTABLE=false
# true = fail CLOSED if the DLP server is unreachable (stops mail during an
# outage). false = keep mail flowing. Choose deliberately.
RELAY_BLOCK_ON_DLP_ERROR=false
