# CyberSentinel DLP - Environment Configuration
# Copy this file to .env and configure with your values

# ============================================
# SECURITY SETTINGS (CHANGE THESE!)
# ============================================
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
JWT_SECRET=change-this-to-a-random-jwt-secret-min-32-chars
ENCRYPTION_KEY=change-this-to-a-random-encryption-key
POSTGRES_PASSWORD=change-this-strong-postgres-password
MONGODB_PASSWORD=change-this-strong-mongodb-password
REDIS_PASSWORD=change-this-strong-redis-password
OPENSEARCH_PASSWORD=change-this-strong-opensearch-password

# ============================================
# TIMEZONE CONFIGURATION
# ============================================
# Timestamps are stored in UTC; this controls display timezone in API responses.
# Examples: UTC, Asia/Kolkata, US/Eastern, Europe/London, America/New_York
APP_TIMEZONE=UTC

# ============================================
# NETWORK CONFIGURATION
# ============================================
# Your Ubuntu server's IP address (used for display purposes)
HOST_IP=your-ubuntu-server-ip
# NOTE: VITE_API_URL is NOT needed when using pre-built GHCR images.
# The dashboard uses relative URLs (/api/v1) and nginx proxies to the backend.

# ============================================
# DATABASE SETTINGS
# ============================================
# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=dlp_user
POSTGRES_DB=cybersentinel_dlp

# MongoDB Configuration
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USER=dlp_user
MONGODB_DB=cybersentinel_dlp

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# OpenSearch Configuration (Event Storage & Search)
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=change-this-strong-opensearch-password
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX_PREFIX=cybersentinel

# ============================================
# APPLICATION SETTINGS
# ============================================
ENVIRONMENT=production
DEBUG=False
PORT=55000
APP_NAME=CyberSentinel DLP
APP_VERSION=2.0.0

# ============================================
# CORS SETTINGS (Add your dashboard URLs)
# ============================================
# SECURITY: CORS and trusted-host allowlists.
# The dashboard is served from the same origin as the API via the nginx
# reverse proxy, so no cross-origin access is needed. Wide-open "*" was
# removed — set these to the explicit hostname(s) you serve the dashboard
# under in production. Example:
#   CORS_ORIGINS=["https://dlp.mycompany.com"]
#   ALLOWED_HOSTS=dlp.mycompany.com,127.0.0.1
CORS_ORIGINS=["http://localhost","http://127.0.0.1"]
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# EMAIL ALERTS (OPTIONAL)
# ============================================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@company.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=dlp-alerts@company.com
ALERT_EMAIL=admin@company.com

# ============================================
# WAZUH SIEM INTEGRATION (OPTIONAL)
# ============================================
WAZUH_ENABLED=false
WAZUH_HOST=your-wazuh-server
WAZUH_PORT=55000
WAZUH_USER=wazuh-api-user
WAZUH_PASSWORD=wazuh-api-password

# ============================================
# LOGGING SETTINGS
# ============================================
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/cybersentinel
MAX_LOG_SIZE_MB=100
LOG_RETENTION_DAYS=30

# ============================================
# QUARANTINE SETTINGS
# ============================================
QUARANTINE_ENABLED=true
QUARANTINE_PATH=/var/quarantine/dlp
QUARANTINE_MAX_SIZE_GB=50

# ============================================
# PERFORMANCE TUNING
# ============================================
MAX_WORKERS=4
MAX_CONNECTIONS=100
REQUEST_TIMEOUT=30

# ============================================
# COMPLIANCE SETTINGS
# ============================================
COMPLIANCE_MODE=GDPR,HIPAA,PCI-DSS
DATA_RETENTION_DAYS=90
AUDIT_LOG_ENABLED=true
